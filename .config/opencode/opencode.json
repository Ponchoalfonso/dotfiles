{
  "$schema": "https://opencode.ai/config.json",

  "permission": {

    // ── File modifications ──────────────────────────────────────────────────
    // edit covers: edit, write, apply_patch, multiedit
    "edit": "ask",

    // ── Bash commands ───────────────────────────────────────────────────────
    // Rules are evaluated top-to-bottom; the LAST matching rule wins.
    // Start with safe read-only commands (allow), end with a catch-all (ask).
    "bash": {

      // ── Read-only / safe ops — allow without interruption ─────────────────

      // Navigation & inspection
      "pwd":            "allow",
      "ls *":           "allow",
      "ls":             "allow",
      "cat *":          "allow",
      "echo *":         "allow",
      "which *":        "allow",
      "type *":         "allow",
      "env":            "allow",
      "printenv *":     "allow",

      // Git read-only
      "git status":     "allow",
      "git status *":   "allow",
      "git diff":       "allow",
      "git diff *":     "allow",
      "git log":        "allow",
      "git log *":      "allow",
      "git show *":     "allow",
      "git branch":     "allow",
      "git branch *":   "allow",
      "git remote *":   "allow",
      "git stash list": "allow",

      // Search & discovery
      "grep *":         "allow",
      "rg *":           "allow",
      "find *":         "allow",
      "fd *":           "allow",

      // Language / runtime version checks
      "node --version": "allow",
      "node -v":        "allow",
      "npm --version":  "allow",
      "npm -v":         "allow",
      "python --version":"allow",
      "python3 --version":"allow",
      "pip --version":  "allow",
      "go version":     "allow",
      "rustc --version":"allow",
      "cargo --version":"allow",

      // Build info & linting (no side-effects)
      "npm run lint":   "allow",
      "npm run lint *": "allow",
      "npm run typecheck": "allow",
      "tsc --noEmit":   "allow",
      "tsc --noEmit *": "allow",

      // ── Write-triggering ops — ask before running ─────────────────────────

      // Package management (installs mutate node_modules / lock files)
      "npm install *":  "ask",
      "npm install":    "ask",
      "npm uninstall *":"ask",
      "npm update *":   "ask",
      "npm ci":         "ask",
      "npx *":          "ask",
      "pnpm install *": "ask",
      "pnpm add *":     "ask",
      "pnpm remove *":  "ask",
      "yarn add *":     "ask",
      "yarn remove *":  "ask",
      "yarn install":   "ask",
      "pip install *":  "ask",
      "pip uninstall *":"ask",
      "cargo add *":    "ask",
      "cargo install *":"ask",
      "go get *":       "ask",
      "go install *":   "ask",

      // Git write ops (commits, pushes, resets alter history)
      "git add *":      "ask",
      "git commit *":   "ask",
      "git push *":     "ask",
      "git pull *":     "ask",
      "git fetch *":    "ask",
      "git merge *":    "ask",
      "git rebase *":   "ask",
      "git reset *":    "ask",
      "git checkout *": "ask",
      "git switch *":   "ask",
      "git stash *":    "ask",
      "git tag *":      "ask",
      "git cherry-pick *": "ask",
      "git clean *":    "ask",

      // File system mutations
      "mkdir *":        "ask",
      "mkdir":          "ask",
      "touch *":        "ask",
      "cp *":           "ask",
      "mv *":           "ask",
      "ln *":           "ask",
      "chmod *":        "ask",
      "chown *":        "ask",

      // Deletions — extra caution (hard deny the most dangerous forms)
      "rm -rf *":       "deny",
      "rm -fr *":       "deny",
      "rm -rf":         "deny",
      "rm *":           "ask",
      "rmdir *":        "ask",

      // Privilege escalation — always ask
      "sudo *":         "ask",
      "su *":           "ask",

      // Shells & code execution that may spawn subprocesses
      "bash *":         "ask",
      "sh *":           "ask",
      "zsh *":          "ask",
      "node *":         "ask",
      "python *":       "ask",
      "python3 *":      "ask",
      "deno *":         "ask",
      "bun *":          "ask",

      // Build & test runners (may write artifacts / run arbitrary code)
      "npm run *":      "ask",
      "npm test":       "ask",
      "npm test *":     "ask",
      "make *":         "ask",
      "cargo build *":  "ask",
      "cargo test *":   "ask",
      "go build *":     "ask",
      "go test *":      "ask",

      // Network / data transfer
      "curl *":         "ask",
      "wget *":         "ask",
      "fetch *":        "ask",

      // Environment & config changes
      "export *":       "ask",
      "source *":       "ask",
      ". *":            "ask",

      // ── Catch-all: ask for anything not explicitly listed ─────────────────
      "*":              "ask"
    },

    // ── Sensitive file reads ─────────────────────────────────────────────────
    "read": {
      "*":              "allow",
      "*.env":          "deny",
      "*.env.*":        "deny",
      "*.env.example":  "allow",
      "*.key":          "deny",
      "*.pem":          "deny",
      "*.p12":          "deny",
      "id_rsa*":        "deny",
      "id_ed25519*":    "deny",
      ".aws/credentials": "deny",
      ".gcloud/**":     "deny"
    },

    // ── External directory access ────────────────────────────────────────────
    "external_directory": "ask",

    // ── Web fetching ─────────────────────────────────────────────────────────
    "webfetch": "ask"
  }
}
